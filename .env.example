# Optional — only needed for daily email digests on Cloudflare Pages.
# Full step-by-step: README.md → "Daily email digests — exact setup (Resend + Cloudflare KV)"
#
# Set these in Cloudflare Dashboard → Workers & Pages → job-scout → Settings → Environment variables
# (not via a local .env for production Pages).

# Resend (https://resend.com) API key for outbound digest email
RESEND_API_KEY=re_xxxxxxxx

# Must use a domain verified in Resend, e.g. Job Scout <digest@yourdomain.com>
DIGEST_FROM_EMAIL=Job Scout <digest@yourdomain.com>

# AES key material for encrypting BYOK Firecrawl keys at rest in KV (min 16 chars)
# Generate: openssl rand -base64 32
DIGEST_ENCRYPTION_KEY=change-me-to-a-long-random-string

# Shared secret for POST /api/digest/run (Authorization: Bearer …)
# Generate: openssl rand -base64 32
CRON_SECRET=change-me-cron-secret

# Public origin used in digest email links (no trailing slash)
PUBLIC_APP_URL=https://job-scout.pages.dev

# CORS — not required for same-origin Pages + Functions
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
